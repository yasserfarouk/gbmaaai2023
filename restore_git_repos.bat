
REM Repository: papers/rejected/2023aamas_bluesky/supplementary
echo Restoring: papers/rejected/2023aamas_bluesky/supplementary
if exist "papers\rejected\2023aamas_bluesky\supplementary\.git" (
    echo   Directory already exists, skipping...
) else (
    REM Create parent directory if needed
    if not exist "papers\rejected\2023aamas_bluesky" mkdir "papers\rejected\2023aamas_bluesky"
    
    REM Clone the repository
    git clone "git@github.com:yasserfarouk/gbmaaai2023.git" "papers\rejected\2023aamas_bluesky\supplementary"
    if errorlevel 1 (
        echo   Failed to clone
    ) else (
        echo   Successfully cloned
        
        REM Checkout the original branch if not already on it
        cd "papers\rejected\2023aamas_bluesky\supplementary"
        git checkout "main" 2>nul
        if errorlevel 1 (
            echo   Could not checkout branch: main
        ) else (
            echo   Checked out branch: main
        )
        cd ..\..
    )
)
echo.


